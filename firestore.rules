rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow read, write, delete: if request.auth != null;
    }
    match /codingLeads/{leadId} {
      allow read, write, delete: if request.auth != null;
    }
    match /codingLeadsConfig/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
