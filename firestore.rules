rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow read, write, delete: if request.auth != null;
    }
    match /codingLeads/{leadId} {
      allow read, write, delete: if request.auth != null;
    }
    match /codingLeadsConfig/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Outreach CRM ────────────────────────────────────────────────────
    match /crmLeads/{leadId} {
      allow read, write, delete: if request.auth != null;

      match /notes/{noteId} {
        allow read, write, delete: if request.auth != null;
      }
      match /tasks/{taskId} {
        allow read, write, delete: if request.auth != null;
      }
    }
    match /crmTemplates/{templateId} {
      allow read, write, delete: if request.auth != null;
    }
    match /crmPortfolio/{demoId} {
      allow read, write, delete: if request.auth != null;
    }
    match /scheduledEmails/{emailId} {
      allow read, write, delete: if request.auth != null;
    }
    // Connection status has no token in it — safe for the client to read.
    match /gmailConnectionStatus/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // only written by Cloud Functions (Admin SDK bypasses rules)
    }
    // Encrypted refresh token — never exposed to the client.
    match /gmailTokens/{docId} {
      allow read, write: if false;
    }
  }
}
